@model IEnumerable<SmartHR.Models.Invoice>

@{
    ViewData["Title"] = "إدارة الفواتير والمالية";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-file-invoice-dollar text-primary me-2"></i> الإدارة المالية</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus me-1"></i> إصدار فاتورة
    </a>
</div>

<div class="card shadow-sm border-0 border-top border-primary border-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">رقم الفاتورة</th>
                        <th>النوع</th>
                        <th>العميل / الجهة</th>
                        <th class="text-center">التاريخ</th>
                        <th class="text-center">المبلغ الإجمالي</th>
                        <th class="text-center">الحالة</th>
                        <th class="text-center">خيارات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@item.InvoiceNumber</td>
                            <td>
                                @if (item.Type == "Sales")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="fas fa-arrow-up me-1"></i> مبيعات</span>
                                }
                                else if (item.Type == "Purchase")
                                {

                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning"><i class="fas fa-arrow-down me-1"></i> مشتريات</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="fas fa-minus me-1"></i> مصروفات</span>
                                }
                            </td>
                            <td class="fw-bold">@(item.Client?.FullName ?? "غير محدد")</td>
                            <td class="text-center small">@item.Date.ToString("dd MMM yyyy")</td>
                            <td class="text-center fw-bold text-primary">@item.TotalAmount.ToString("N2")</td>
                            <td class="text-center">
                                @if (item.Status == "Paid")
                                {
                                    <span class="badge bg-success">مدفوعة</span>
                                }
                                else if (item.Status == "Overdue")
                                {

                                    <span class="badge bg-danger">متأخرة</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary">غير مدفوعة</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-light text-success border" title="طباعة"><i class="fas fa-print"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info border"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border"><i class="fas fa-edit"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>