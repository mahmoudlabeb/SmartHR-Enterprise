@model IEnumerable<SmartHR.Models.InvoiceItem>

<div class="table-responsive mb-4">
    <table class="table table-bordered table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th width="50%">البيان / الوصف</th>
                <th class="text-center" width="15%">الكمية</th>
                <th class="text-center" width="15%">سعر الوحدة</th>
                <th class="text-center" width="20%">الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        لا توجد بنود مضافة لهذه الفاتورة حتى الآن.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-dark">@item.Description</td>
                        <td class="text-center">@item.Quantity.ToString("0.##")</td>
                        <td class="text-center">@item.UnitPrice.ToString("N2")</td>
                        <td class="text-center fw-bold text-primary">@item.TotalPrice.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>