@model SmartHR.Models.Client

@{
    ViewData["Title"] = "ملف العميل";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-id-badge text-info me-2"></i> ملف العميل</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="fas fa-edit me-1"></i> تعديل البيانات</a>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-list me-1"></i> قائمة العملاء</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 h-100 text-center">
            <div class="card-body pt-5">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=0D8ABC&color=fff&size=120" class="rounded-circle shadow mb-3" />
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted mb-3">
                    <i class="fas fa-building me-1"></i> @(string.IsNullOrEmpty(Model.CompanyName) ? "عميل فردي" : Model.CompanyName)
                </p>

                @if (Model.IsActive)
                {
                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-4 py-2 fs-6">عميل نشط</span>
                }
                else
                {
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-4 py-2 fs-6">غير نشط</span>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 fw-bold text-dark"><i class="fas fa-address-card text-primary me-2"></i> بيانات التواصل</h6>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-sm-3 text-muted fw-bold">البريد الإلكتروني:</div>
                    <div class="col-sm-9 fw-bold">
                        <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                    </div>
                </div>
                <hr class="bg-light" />
                <div class="row mb-4">
                    <div class="col-sm-3 text-muted fw-bold">رقم الهاتف:</div>
                    <div class="col-sm-9 fw-bold">
                        <a href="tel:@Model.PhoneNumber" class="text-decoration-none text-dark">@Model.PhoneNumber</a>
                    </div>
                </div>
                <hr class="bg-light" />
                <div class="row mb-4">
                    <div class="col-sm-3 text-muted fw-bold">العنوان:</div>
                    <div class="col-sm-9">@(string.IsNullOrEmpty(Model.Address) ? "غير مسجل" : Model.Address)</div>
                </div>
                <hr class="bg-light" />
                <div class="row">
                    <div class="col-sm-3 text-muted fw-bold">تاريخ الإضافة:</div>
                    <div class="col-sm-9"><i class="far fa-calendar-alt text-secondary me-1"></i> @Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                </div>
            </div>
        </div>
    </div>
</div>