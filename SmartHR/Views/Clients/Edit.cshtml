@model SmartHR.Models.Client

@{
    ViewData["Title"] = "تعديل بيانات العميل";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-edit text-primary me-2"></i> تعديل بيانات العميل</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <h5 class="fw-bold mb-3 text-primary">البيانات الأساسية</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-bold">اسم العميل</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CompanyName" class="form-label fw-bold">اسم الشركة</label>
                            <input asp-for="CompanyName" class="form-control" />
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h5 class="fw-bold mb-3 text-primary">بيانات التواصل</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">البريد الإلكتروني</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">رقم الهاتف</label>
                            <input asp-for="PhoneNumber" class="form-control" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-bold">العنوان</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="form-check form-switch fs-5 mb-4 bg-light p-3 rounded">
                        <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsActive">
                        <label class="form-check-label fw-bold" asp-for="IsActive">حساب العميل نشط</label>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-light border"><i class="fas fa-arrow-right me-1"></i> تراجع</a>
                        <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i> حفظ التعديلات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}