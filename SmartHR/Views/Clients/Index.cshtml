@model IEnumerable<SmartHR.Models.Client>

@{
    ViewData["Title"] = "إدارة العملاء";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-handshake text-primary me-2"></i> إدارة العملاء</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-user-plus me-1"></i> إضافة عميل جديد
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 border-top border-primary border-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">اسم العميل</th>
                        <th>الشركة / المؤسسة</th>
                        <th>معلومات التواصل</th>
                        <th class="text-center">الحالة</th>
                        <th class="text-center">تاريخ الإضافة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-users-slash fa-3x mb-3 opacity-50"></i>
                                <h5>لا يوجد عملاء مسجلين حتى الآن.</h5>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="fas fa-user-tie text-secondary me-2"></i>@item.FullName
                                </td>
                                <td><span class="badge bg-light text-dark border">@(string.IsNullOrEmpty(item.CompanyName) ? "فردي" : item.CompanyName)</span></td>
                                <td>
                                    <div class="small"><i class="fas fa-envelope text-muted me-1"></i> @item.Email</div>
                                    <div class="small"><i class="fas fa-phone-alt text-muted me-1"></i> @item.PhoneNumber</div>
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill">غير نشط</span>
                                    }
                                </td>
                                <td class="text-center text-muted small">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border" title="تعديل"><i class="fas fa-edit"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info border" title="تفاصيل"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger border" title="حذف"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>