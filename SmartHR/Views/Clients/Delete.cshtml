@model SmartHR.Models.Client

@{
    ViewData["Title"] = "حذف عميل";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2 text-danger"><i class="fas fa-user-times me-2"></i> تأكيد الحذف</h1>
</div>

<div class="alert alert-danger shadow-sm p-4" role="alert">
    <h4 class="alert-heading fw-bold mb-3">هل أنت متأكد من رغبتك في حذف هذا العميل؟</h4>
    <p>سيتم حذف بيانات العميل <strong>(@Model.FullName)</strong> نهائياً من النظام. إذا كان هناك فواتير أو مشاريع مرتبطة بهذا العميل، يفضل تعطيل حسابه (جعله غير نشط) بدلاً من حذفه بالكامل لتجنب فقدان البيانات المرجعية.</p>
    <hr>

    <div class="bg-white p-3 rounded text-dark mt-3 d-flex align-items-center">
        <i class="fas fa-building fa-2x text-danger opacity-50 me-3"></i>
        <div>
            <h5 class="mb-1 fw-bold">@Model.FullName</h5>
            <p class="text-muted small mb-0">@(string.IsNullOrEmpty(Model.CompanyName) ? "بدون شركة" : Model.CompanyName) | @Model.Email</p>
        </div>
    </div>
</div>

<form asp-action="Delete" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger px-4 me-2"><i class="fas fa-trash-alt me-2"></i> نعم، احذف العميل</button>
    <a asp-action="Index" class="btn btn-light border">تراجع والعودة للقائمة</a>
</form>