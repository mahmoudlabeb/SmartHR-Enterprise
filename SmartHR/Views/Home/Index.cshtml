@{
    Layout = null; // Standalone landing page
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مرحباً بك - SmartHR</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #09090b 0%, #171720 100%);
            color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Glassmorphism Navbar */
        .navbar-custom {
            background: rgba(23, 23, 32, 0.7);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding: 1rem 0;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: #f8f9fa !important;
            letter-spacing: -0.5px;
        }
        .brand-accent {
            color: #6366f1;
        }

        /* Hero Section */
        .hero-section {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 100px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .hero-bg-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, rgba(0,0,0,0) 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 0;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 800px;
            padding: 2rem;
        }

        .hero-title {
            font-size: 4rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            background: linear-gradient(to right, #ffffff, #a5b4fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: #9ca3af;
            margin-bottom: 3rem;
            line-height: 1.6;
        }

        /* Buttons */
        .btn-custom {
            padding: 1rem 2.5rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            margin: 0.5rem;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white !important;
            border: none;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
        }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.6);
        }

        .btn-outline-custom {
            background: transparent;
            color: #e5e7eb !important;
            border: 1px solid rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
        }

        .btn-outline-custom:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.4);
            transform: translateY(-2px);
        }

        /* Features List */
        .features {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-top: 4rem;
            flex-wrap: wrap;
        }
        .feature-item {
            display: flex;
            align-items: center;
            color: #d1d5db;
            font-weight: 500;
        }
        .feature-item i {
            color: #6366f1;
            margin-left: 0.5rem;
            font-size: 1.2rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="navbar-brand" href="/">Smart<span class="brand-accent">HR</span></a>
            <div>
                <a href="/Account/Login" class="btn btn-sm btn-outline-light rounded-pill px-3 me-2" style="border-color: rgba(255,255,255,0.2);">دخول الإدارة</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-bg-glow"></div>
        <div class="hero-content">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 mb-4">النظام المتقدم لإدارة الموارد البشرية</span>
            
            <h1 class="hero-title">مستقبل إدارة مؤسستك<br>يبدأ من هنا</h1>
            
            <p class="hero-subtitle">
                منصة متكاملة لإدارة الموظفين، الرواتب، الحضور والانصراف، والتقييمات. 
                انضم إلينا الآن للوصول إلى بيئة عمل أذكى وأكثر إنتاجية.
            </p>

            <div>
                <a href="/Account/Register" class="btn-custom btn-primary-custom">
                    <i class="fas fa-rocket ms-2"></i> طلب انضمام كـ موظف / زائر
                </a>
                <a href="/Account/Login" class="btn-custom btn-outline-custom">
                    <i class="fas fa-sign-in-alt ms-2"></i> تسجيل الدخول
                </a>
            </div>

            <div class="features">
                <div class="feature-item">
                    <i class="fas fa-check-circle"></i> بنية مؤسسية آمنة
                </div>
                <div class="feature-item">
                    <i class="fas fa-bolt"></i> أداء استثنائي سريع
                </div>
                <div class="feature-item">
                    <i class="fas fa-shield-alt"></i> نظام صلاحيات دقيق
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
