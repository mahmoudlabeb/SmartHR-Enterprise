@{
    ViewData["Title"] = "منتجات ومميزات الشركة";
    Layout = "_ClientLayout";
}

<div class="container mt-4">
    <div class="row mb-5 text-center">
        <div class="col-md-12">
            <h1 class="display-4 fw-bold text-primary">مرحباً بك في بوابة العملاء</h1>
            <p class="lead text-muted">اكتشف أحدث منتجاتنا ومميزاتنا المصممة خصيصاً لك</p>
        </div>
    </div>

    <!-- Products Section -->
    <div class="row mb-5">
        <div class="col-md-12 mb-4">
            <h2 class="border-bottom pb-2"><i class="fas fa-box-open text-warning me-2"></i> منتجاتنا</h2>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="display-4 text-primary mb-3">
                        <i class="fas fa-laptop-code"></i>
                    </div>
                    <h4 class="card-title">نظام إدارة الموارد البشرية SmartHR</h4>
                    <p class="card-text text-muted">نظام متكامل وشامل لإدارة كل ما يتعلق بالموارد البشرية من حضور، رواتب، وتقييم الأداء.</p>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-4">
                    <button class="btn btn-outline-primary rounded-pill">تعرف على المزيد</button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="display-4 text-success mb-3">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4 class="card-title">منظومة الإدارة المالية الذكية</h4>
                    <p class="card-text text-muted">تتبع وتدقيق جميع المصروفات، الفواتير، وحسابات الشركة بسهولة تامة من مكان واحد.</p>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-4">
                    <button class="btn btn-outline-success rounded-pill">تعرف على المزيد</button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="display-4 text-info mb-3">
                        <i class="fas fa-project-diagram"></i>
                    </div>
                    <h4 class="card-title">نظام إدارة المشاريع المتطور</h4>
                    <p class="card-text text-muted">تحكم كامل في مشاريعك ووزع المهام على فرق العمل بشكل سلس لضمان إنتاجية أعلى.</p>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-4">
                    <button class="btn btn-outline-info rounded-pill">تعرف على المزيد</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row align-items-center mb-5 bg-light rounded-4 p-5 shadow-sm">
        <div class="col-md-6">
            <h2 class="mb-4">لماذا تختار أنظمتنا؟</h2>
            <ul class="list-unstyled mb-0">
                <li class="mb-3 d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle p-2 me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-check"></i>
                    </div>
                    <span class="fs-5">حماية للبيانات بأحدث تقنيات التشفير.</span>
                </li>
                <li class="mb-3 d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle p-2 me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <span class="fs-5">سرعة فائقة في أداء المهام وعرض التقارير.</span>
                </li>
                <li class="mb-3 d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle p-2 me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <span class="fs-5">واجهة مستخدم متجاوبة مع جميع الأجهزة والهواتف.</span>
                </li>
                <li class="d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle p-2 me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-headset"></i>
                    </div>
                    <span class="fs-5">دعم فني متواصل وحلول تضمن استمرارية العمل.</span>
                </li>
            </ul>
        </div>
        <div class="col-md-6 text-center mt-4 mt-md-0">
            <img src="https://via.placeholder.com/500x350.png?text=SmartHR+Features" alt="Features Image" class="img-fluid rounded-4 shadow" />
        </div>
    </div>
</div>