@model IEnumerable<SmartHR.Models.Salary>

@{
    ViewData["Title"] = "مسير الرواتب";
}

@using SmartHR.Models
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-money-check-alt text-success me-2"></i> مسير الرواتب (Payroll)</h1>
    @if (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.SuperAdmin) || User.IsInRole(AppRoles.HR))
    {
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-plus me-1"></i> إصدار راتب جديد
        </a>
    }
</div>

<div class="card shadow-sm border-0 border-top border-success border-4 text-white bg-dark">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">الموظف</th>
                        <th class="text-center">الشهر / السنة</th>
                        <th class="text-center">الأساسي</th>
                        <th class="text-center">الصافي</th>
                        <th class="text-center">الحالة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">
                                <i class="fas fa-user-circle text-secondary me-2"></i>@(item.Employee?.FullName ?? "غير محدد")
                            </td>
                            <td class="text-center fw-bold text-muted">@item.Month / @item.Year</td>
                            <td class="text-center">@item.BasicSalary.ToString("N2")</td>
                            <td class="text-center fw-bold text-primary">@item.NetSalary.ToString("N2")</td>
                            <td class="text-center">
                                @if (item.Status == SalaryStatus.Paid)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i> مدفوع</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i> معلق</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="PrintPaySlipPdf" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="طباعة (PDF)" target="_blank"><i class="fas fa-file-pdf"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary @( (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.SuperAdmin) || User.IsInRole(AppRoles.HR)) ? "" : "disabled d-none")" title="تعديل"><i class="fas fa-edit"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>