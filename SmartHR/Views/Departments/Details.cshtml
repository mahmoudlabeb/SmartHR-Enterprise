@model SmartHR.Models.Department

@{
    ViewData["Title"] = "تفاصيل القسم";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-info-circle text-info me-2"></i> بيانات القسم</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit me-1"></i> تعديل</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-list me-1"></i> القائمة</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-light fw-bold py-3">
        <i class="fas fa-building text-secondary me-2"></i> @Model.Name
    </div>
    <div class="card-body p-4">
        <div class="row mb-3">
            <div class="col-md-3 fw-bold text-muted">اسم القسم:</div>
            <div class="col-md-9 fs-5 text-primary">@Model.Name</div>
        </div>
        <hr />
        <div class="row mb-3">
            <div class="col-md-3 fw-bold text-muted">الوصف والمهام:</div>
            <div class="col-md-9">@(string.IsNullOrEmpty(Model.Description) ? "لا يوجد وصف مسجل." : Model.Description)</div>
        </div>
        <hr />
        <div class="row">
            <div class="col-md-3 fw-bold text-muted">تاريخ الإنشاء:</div>
            <div class="col-md-9"><i class="far fa-calendar-alt text-secondary me-1"></i> @Model.CreatedAt.ToString("dd MMMM yyyy, hh:mm tt")</div>
        </div>
    </div>
</div>