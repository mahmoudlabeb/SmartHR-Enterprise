@model SmartHR.Models.Ticket

@{
    ViewData["Title"] = "فتح تذكرة جديدة";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-plus-circle text-danger me-2"></i> فتح تذكرة دعم فني</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-danger border-4">
            <div class="card-body p-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-bold">موضوع التذكرة <span class="text-danger">*</span></label>
                        <input asp-for="Subject" class="form-control form-control-lg" placeholder="اكتب ملخص المشكلة أو الطلب بإيجاز..." required />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">التفاصيل <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="اشرح المشكلة بالتفصيل لمساعدة فريق الدعم في حلها بسرعة..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label for="attachment" class="form-label fw-bold"><i class="fas fa-paperclip me-1"></i> إرفاق ملف (اختياري)</label>
                        <input type="file" name="attachment" id="attachment" class="form-control" accept="image/*,.pdf,.doc,.docx" />
                        <div class="form-text">الحد الأقصى للملف 5 ميجابايت (صور أو مستندات)</div>
                    </div>

                    <div class="row bg-light p-3 rounded mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Priority" class="form-label fw-bold">مستوى الأهمية (الأولوية)</label>
                            <select asp-for="Priority" class="form-select border-warning">
                                <option value="Low">عادية</option>
                                <option value="Medium" selected>متوسطة</option>
                                <option value="High">عاجلة جداً</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmployeeId" class="form-label fw-bold">مقدم الطلب</label>
                            <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId">
                                <option value="">-- اختر الموظف --</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-light border"><i class="fas fa-times me-1"></i> إلغاء</a>
                        <button type="submit" class="btn btn-danger px-5"><i class="fas fa-paper-plane me-2"></i> إرسال التذكرة</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}