@model IEnumerable<SmartHR.Models.ApplicationUser>
@{
    ViewData["Title"] = "الرسائل والمحادثات";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold text-success"><i class="fas fa-comments me-2"></i> الرسائل والمحادثات</h1>
</div>

<div class="row">
    <div class="col-md-4">
        <!-- Sidebar with Users -->
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom pb-0 pt-3">
                <h5 class="card-title fw-bold text-success"><i class="fas fa-users me-2"></i> المحادثات</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush rounded-0" style="max-height: 70vh; overflow-y: auto;">
                    @foreach (var user in Model)
                    {
                        var unreadCounts = ViewBag.UnreadCounts as Dictionary<string, int>;
                        int unread = unreadCounts != null && unreadCounts.ContainsKey(user.Id) ? unreadCounts[user.Id] : 0;
                        string textStyle = unread > 0 ? "fw-bolder text-dark" : "fw-bold";
                        string backgroundStyle = unread > 0 ? "bg-light border-start border-4 border-success" : "";

                        <a href="@Url.Action("Conversation", "Chat", new { id = user.Id })" class="list-group-item list-group-item-action d-flex align-items-center py-3 border-bottom @backgroundStyle">
                            <div class="fs-4 text-secondary me-3 position-relative">
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 @textStyle">@user.FullName</h6>
                                <small class="text-muted"><i class="fas fa-envelope me-1"></i>@user.Email</small>
                            </div>
                            @if (unread > 0)
                            {
                                <span class="badge bg-danger rounded-pill shadow-sm">@unread</span>
                            }
                            <i class="fas fa-chevron-left text-muted small ms-2"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center p-5">
                <div class="display-1 text-light mb-3">
                    <i class="fas fa-comment-dots"></i>
                </div>
                <h4 class="text-muted fw-bold">اختر محادثة للبدء</h4>
                <p class="text-muted mb-0">يمكنك النقر على اسم الموظف من القائمة لفتح المحادثة المباشرة معه.</p>
            </div>
        </div>
    </div>
</div>