@model SmartHR.ViewModels.PermissionMatrixViewModel

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle mb-0 text-center">
        <thead class="table-dark">
            <tr>
                <th class="text-start ps-3" style="width: 20%; min-width: 200px;">
                    <i class="fas fa-user-tag me-2"></i> اسم الدور (Role)
                </th>
                @foreach (var module in Model.AvailableModules)
                {
                    <th style="min-width: 120px;">
                        @if (module.Contains("موظفين") || module.Contains("HR"))
                        {
                            <i class="fas fa-users text-info d-block mb-1 fs-5"></i>
                        }
                        else if (module.Contains("مالية") || module.Contains("رواتب"))
                        {

                            <i class="fas fa-money-bill-wave text-success d-block mb-1 fs-5"></i>
                        }
                        else if (module.Contains("مشاريع"))
                        {

                            <i class="fas fa-project-diagram text-warning d-block mb-1 fs-5"></i>
                        }
                        else
                        {

                            <i class="fas fa-cube text-light d-block mb-1 fs-5"></i>
                        }
                        @module
                    </th>
                }
            </tr>
        </thead>
        <tbody class="bg-white">
            @for (int i = 0; i < Model.Roles.Count; i++)
            {
                <tr>
                    <td class="text-start ps-3 fw-bold bg-light">
                        <input type="hidden" asp-for="Roles[i].RoleId" />
                        <input type="hidden" asp-for="Roles[i].RoleName" />

                        @if (Model.Roles[i].RoleName == "SuperAdmin" || Model.Roles[i].RoleName == "Admin")
                        {
                            <span class="text-danger"><i class="fas fa-crown me-1"></i> @Model.Roles[i].RoleName</span>
                        }
                        else
                        {
                            <span class="text-primary">@Model.Roles[i].RoleName</span>
                        }
                    </td>

                    @for (int j = 0; j < Model.Roles[i].Permissions.Count; j++)
                    {
                        <td>
                            <input type="hidden" asp-for="Roles[i].Permissions[j].ModuleName" />

                            @if (Model.Roles[i].RoleName == "SuperAdmin" || Model.Roles[i].RoleName == "Admin")
                            {
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input bg-success border-success" type="checkbox" checked disabled>
                                </div>
                            }
                            else
                            {
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input asp-for="Roles[i].Permissions[j].IsGranted" class="form-check-input cursor-pointer" type="checkbox">
                                </div>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
        transform: scale(1.2);
    }

    .table-dark th {
        background-color: #2c3e50;
        color: #fff;
        border-color: #34495e;
        vertical-align: middle;
    }
</style>