@model SmartHR.ViewModels.CompanyInfoViewModel

@{
    ViewData["Title"] = "بيانات الشركة";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-building text-primary me-2"></i> بيانات الشركة (Company Profile)</h1>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-arrow-right me-1"></i> العودة للإعدادات</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-4">
                <form asp-action="CompanyInfo" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="CompanyName" class="form-label fw-bold">اسم الشركة (الرسمي)</label>
                            <input asp-for="CompanyName" class="form-control" placeholder="مثال: شركة التقنية الذكية المحدودة" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TaxNumber" class="form-label fw-bold">الرقم الضريبي (VAT)</label>
                            <input asp-for="TaxNumber" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">رقم الهاتف الأساسي</label>
                            <input asp-for="PhoneNumber" class="form-control" dir="ltr" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">البريد الإلكتروني للشركة</label>
                            <input asp-for="Email" type="email" class="form-control" dir="ltr" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-bold">العنوان الوطني / التفصيلي</label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">شعار الشركة (Logo)</label>
                        <input type="file" name="CompanyLogo" class="form-control" accept="image/png, image/jpeg" />
                        <div class="form-text small text-muted">يفضل أن تكون الصورة بصيغة PNG وبخلفية شفافة (حجم أقصى 2MB).</div>
                    </div>

                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i> حفظ التحديثات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>