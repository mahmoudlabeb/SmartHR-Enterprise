@model SmartHR.ViewModels.ThemeViewModel

@{
    ViewData["Title"] = "المظهر والتخصيص";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-paint-roller text-warning me-2"></i> تخصيص المظهر (Theme)</h1>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-arrow-right me-1"></i> العودة للإعدادات</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 border-top border-warning border-4">
            <div class="card-body p-4">
                <form asp-action="Theme" method="post">

                    <div class="mb-4">
                        <label class="form-label fw-bold d-block">وضع العرض (Theme Mode)</label>

                        <div class="btn-group w-100 shadow-sm" role="group">
                            <input type="radio" class="btn-check" asp-for="ThemeMode" value="Light" id="modeLight">
                            <label class="btn btn-outline-primary py-3" for="modeLight">
                                <i class="fas fa-sun fs-4 d-block mb-2"></i> الوضع النهاري
                            </label>

                            <input type="radio" class="btn-check" asp-for="ThemeMode" value="Dark" id="modeDark">
                            <label class="btn btn-outline-dark py-3" for="modeDark">
                                <i class="fas fa-moon fs-4 d-block mb-2"></i> الوضع الليلي
                            </label>

                            <input type="radio" class="btn-check" asp-for="ThemeMode" value="System" id="modeSystem">
                            <label class="btn btn-outline-secondary py-3" for="modeSystem">
                                <i class="fas fa-desktop fs-4 d-block mb-2"></i> حسب النظام
                            </label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PrimaryColor" class="form-label fw-bold">لون النظام الأساسي (Primary Color)</label>
                        <div class="d-flex align-items-center">
                            <input asp-for="PrimaryColor" type="color" class="form-control form-control-color border-0 p-0 shadow-sm me-3" style="width: 50px; height: 50px;" title="اختر اللون">
                            <div class="small text-muted">اختر اللون الذي يمثل الهوية البصرية لشركتك. سيتم تطبيقه على الأزرار والقوائم الرئيسية.</div>
                        </div>
                    </div>

                    <div class="text-end border-top pt-3 mt-4">
                        <button type="submit" class="btn btn-warning text-dark fw-bold px-5"><i class="fas fa-palette me-2"></i> حفظ المظهر</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>