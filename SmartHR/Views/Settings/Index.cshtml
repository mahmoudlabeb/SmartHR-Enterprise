@model SmartHR.Models.ApplicationUser

@{
    ViewData["Title"] = "Notification Settings";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <div class="card mt-4">
        <div class="card-body">
            <form asp-action="UpdatePreferences" method="post">
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="receiveEmail" name="receiveEmail" value="true" @(Model.ReceiveEmailNotifications ? "checked" : "")>
                    <label class="form-check-label" for="receiveEmail">Receive Email Notifications</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="receivePush" name="receivePush" value="true" @(Model.ReceivePushNotifications ? "checked" : "")>
                    <label class="form-check-label" for="receivePush">Receive Push Alerts</label>
                </div>
                <button type="submit" class="btn btn-primary">Save Preferences</button>
            </form>
        </div>
    </div>
</div>
