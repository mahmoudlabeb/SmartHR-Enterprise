@model IEnumerable<SmartHR.Models.Attendance>

<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>الموظف</th>
                <th>التاريخ</th>
                <th class="text-center">وقت الدخول</th>
                <th class="text-center">وقت الخروج</th>
                <th class="text-center">ساعات العمل</th>
                <th class="text-center">الحالة</th>
                <th class="text-center">خيارات</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <i class="fas fa-calendar-times fa-2x mb-2 opacity-50"></i>
                        <p class="mb-0">لا توجد سجلات حضور في هذه الفترة.</p>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">
                            <i class="fas fa-user-circle text-secondary me-1"></i> @(item.Employee?.FullName ?? "غير معروف")
                        </td>
                        <td>@item.Date.ToString("dd MMMM yyyy")</td>

                        <td class="text-center text-success fw-bold">
                            @(item.PunchIn.HasValue? item.PunchIn.Value.ToString(@"hh\:mm") : "--:--")
                        </td>

                        <td class="text-center text-danger fw-bold">
                            @(item.PunchOut.HasValue? item.PunchOut.Value.ToString(@"hh\:mm") : "--:--")
                        </td>

                        <td class="text-center fw-bold text-info">
                            @if (item.PunchIn.HasValue && item.PunchOut.HasValue)
                            {
                                var workHours = item.PunchOut.Value.Subtract(item.PunchIn.Value);
                                <span>@workHours.ToString(@"hh\:mm")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>

                        <td class="text-center">
                            @if (item.Status == "Present")
                            {
                                <span class="badge bg-success">حاضر</span>
                            }
                            else if (item.Status == "Late")
                            {
                                <span class="badge bg-warning text-dark">متأخر</span>
                            }
                            else if (item.Status == "Absent")
                            {
                                <span class="badge bg-danger">غائب</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.Status</span>
                            }
                        </td>

                        <td class="text-center">
                            @if (User.IsInRole(SmartHR.Models.AppRoles.SuperAdmin) || User.IsInRole(SmartHR.Models.AppRoles.Admin) || User.IsInRole(SmartHR.Models.AppRoles.HR) || User.IsInRole(SmartHR.Models.AppRoles.Manager))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="تعديل يدوي"><i class="fas fa-edit"></i></a>
                            }
                            else
                            {
                                <span class="text-muted small"><i class="fas fa-lock"></i> مقفل</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>