@model SmartHR.Models.Leave

<div class="card border-0 shadow-sm bg-light">
    <div class="card-body">
        <h6 class="fw-bold mb-3"><i class="fas fa-user-check me-2"></i> اتخاذ إجراء بشأن الطلب</h6>
        <div class="d-flex gap-2">
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-success px-4">
                    <i class="fas fa-check me-1"></i> موافقة
                </button>
            </form>

            <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="fas fa-times me-1"></i> رفض الطلب
                </button>
            </form>
        </div>
    </div>
</div>