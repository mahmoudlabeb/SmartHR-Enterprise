@model IEnumerable<SmartHR.Models.Leave>

@{
    ViewData["Title"] = "سجل إجازاتي";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-user-clock text-info me-2"></i> سجل إجازاتي</h1>
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus me-1"></i> طلب إجازة جديد</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge bg-light text-dark">@item.LeaveType</span>
                        <span class="badge @(item.Status == "Pending" ? "bg-warning text-dark" : item.Status == "Approved" ? "bg-success" : "bg-danger")">
                            @item.Status
                        </span>
                    </div>
                    <h6 class="fw-bold"><i class="far fa-calendar-alt me-2 text-info"></i> الفترة:</h6>
                    <p class="small text-muted mb-3">من @item.StartDate.ToShortDateString() إلى @item.EndDate.ToShortDateString()</p>

                    <p class="card-text small text-truncate"><strong>السبب:</strong> @item.Reason</p>
                </div>
            </div>
        </div>
    }
</div>