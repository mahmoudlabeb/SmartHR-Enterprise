@model SmartHR.ViewModels.ProjectReportViewModel
@{
    ViewData["Title"] = "تقرير إنجاز المشاريع";
}

<style>
    @@media print {
        body {
            background-color: #fff !important;
        }

        .d-print-none {
            display: none !important;
        }

        .card {
            border: none !important;
        }
    }
</style>

<div class="d-print-none d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-chart-line text-warning me-2"></i> تقرير أداء المشاريع</h1>
    <button onclick="window.print()" class="btn btn-secondary shadow-sm"><i class="fas fa-print me-1"></i> طباعة التقرير</button>
</div>

<div class="card shadow-sm border-0 mb-4 d-print-none bg-light">
    <div class="card-body">
        <form method="get" class="row align-items-end">
            <div class="col-md-8 mb-3 mb-md-0">
                <label class="form-label fw-bold">حالة المشروع</label>
                <select asp-for="StatusFilter" class="form-select">
                    <option value="">-- كل المشاريع --</option>
                    <option value="Active">جارية</option>
                    <option value="Completed">مكتملة</option>
                    <option value="Delayed">متأخرة</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-warning text-dark fw-bold w-100"><i class="fas fa-filter me-1"></i> تصفية</button>
            </div>
        </form>
    </div>
</div>

<div class="d-none d-print-block text-center mb-4">
    <h3 class="fw-bold">تقرير حالة المشاريع</h3>
    <p class="text-muted">تاريخ الطباعة: @DateTime.Now.ToString("dd/MM/yyyy")</p>
</div>

<div class="table-responsive shadow-sm rounded border">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark text-center">
            <tr>
                <th class="text-start ps-3" width="30%">اسم المشروع</th>
                <th width="20%">العميل</th>
                <th width="15%">تاريخ التسليم</th>
                <th width="20%">نسبة الإنجاز</th>
                <th width="15%">الحالة</th>
            </tr>
        </thead>
        <tbody class="text-center bg-white">
            @if (!Model.Projects.Any())
            {
                <tr><td colspan="5" class="py-4">لا توجد مشاريع مسجلة.</td></tr>
            }
            @foreach (var proj in Model.Projects)
            {
                <tr>
                    <td class="text-start ps-3 fw-bold text-primary">@proj.ProjectName</td>
                    <td><i class="fas fa-building text-muted me-1"></i> @proj.ClientName</td>
                    <td class="@(proj.EndDate < DateTime.Today && proj.Progress < 100 ? "text-danger fw-bold" : "")">@proj.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="d-flex align-items-center justify-content-center">
                            <span class="me-2 small fw-bold">@proj.Progress%</span>
                            <div class="progress w-75" style="height: 8px;">
                                <div class="progress-bar @(proj.Progress == 100 ? "bg-success" : "bg-warning")" role="progressbar" style="width: @proj.Progress%"></div>
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (proj.Status == "Completed" || proj.Progress == 100)
                        {
                            <span class="badge bg-success">مكتمل</span>
                        }
                        else if (proj.EndDate < DateTime.Today)
                        {

                            <span class="badge bg-danger">متأخر</span>
                        }
                        else
                        {

                            <span class="badge bg-primary">جاري العمل</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>