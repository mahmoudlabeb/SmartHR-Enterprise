@model SmartHR.ViewModels.EmployeeReportViewModel
@{
    ViewData["Title"] = "تقرير بيانات الموظفين";
}

<style>
    @@media print {
        body {
            background-color: #fff !important;
        }

        .d-print-none, nav, aside {
            display: none !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        main {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }
    }
</style>

<div class="d-print-none d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-users text-primary me-2"></i> تقرير القوى العاملة</h1>
    <div>
        <button onclick="window.print()" class="btn btn-secondary shadow-sm me-2"><i class="fas fa-print me-1"></i> طباعة</button>
        <button class="btn btn-success shadow-sm"><i class="fas fa-file-excel me-1"></i> تصدير Excel</button>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 d-print-none bg-light">
    <div class="card-body">
        <form method="get" class="row align-items-end">
            <div class="col-md-4 mb-3 mb-md-0">
                <label class="form-label fw-bold">القسم</label>
                <select asp-for="DepartmentFilter" class="form-select">
                    <option value="">-- جميع الأقسام --</option>
                    <option value="IT">تقنية المعلومات</option>
                    <option value="HR">الموارد البشرية</option>
                    <option value="Finance">المالية</option>
                </select>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <label class="form-label fw-bold">حالة الموظف</label>
                <select asp-for="StatusFilter" class="form-select">
                    <option value="">-- الكل --</option>
                    <option value="Active">على رأس العمل</option>
                    <option value="OnLeave">في إجازة</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> تصفية التقرير</button>
            </div>
        </form>
    </div>
</div>

<div class="d-none d-print-block text-center mb-4 pb-3 border-bottom">
    <h2 class="fw-bold">SmartHR - تقرير القوى العاملة</h2>
    <p class="text-muted">تاريخ الإصدار: @DateTime.Now.ToString("dd/MM/yyyy")</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-bordered table-striped align-middle mb-0 text-center">
            <thead class="table-dark">
                <tr>
                    <th class="text-start ps-3">اسم الموظف</th>
                    <th>القسم</th>
                    <th>المسمى الوظيفي</th>
                    <th>تاريخ التعيين</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Employees.Any())
                {
                    <tr><td colspan="5" class="py-4 text-muted">لا توجد بيانات مطابقة للبحث.</td></tr>
                }
                else
                {
                    @foreach (var emp in Model.Employees)
                    {
                        <tr>
                            <td class="text-start ps-3 fw-bold">@emp.Name</td>
                            <td>@emp.Department</td>
                            <td>@emp.JobTitle</td>
                            <td>@emp.JoinDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(emp.Status == "Active" ? "bg-success" : "bg-warning text-dark") border">@emp.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>