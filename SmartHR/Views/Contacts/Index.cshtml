@model IEnumerable<SmartHR.Models.Contact>

@{
    ViewData["Title"] = "دليل جهات الاتصال";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-address-book text-primary me-2"></i> دليل جهات الاتصال</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus me-1"></i> إضافة جهة اتصال
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-address-card fa-3x mb-3 opacity-50"></i>
            <h5>لا توجد جهات اتصال مسجلة في الدليل حالياً.</h5>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                <div class="card shadow-sm border-0 h-100 hover-shadow">
                    <div class="card-body text-center pt-4">
                        <img src="https://ui-avatars.com/api/?name=@item.Name&background=random&color=fff&size=80" class="rounded-circle shadow-sm mb-3" alt="@item.Name" />

                        <h5 class="fw-bold mb-1 text-dark text-truncate" title="@item.Name">@item.Name</h5>
                        <p class="text-muted small mb-2">
                            @(string.IsNullOrEmpty(item.JobTitle) ? "" : item.JobTitle + " - ")
                            <span class="fw-bold">@(string.IsNullOrEmpty(item.Company) ? "مستقل" : item.Company)</span>
                        </p>

                        <span class="badge bg-light text-secondary border mb-3">@(item.ContactGroup ?? "عام")</span>

                        <ul class="list-unstyled text-start small bg-light p-2 rounded mb-0">
                            <li class="mb-2 text-truncate" title="@item.Phone">
                                <i class="fas fa-phone-alt text-success me-2"></i><a href="tel:@item.Phone" class="text-decoration-none text-dark fw-bold">@item.Phone</a>
                            </li>
                            <li class="text-truncate" title="@item.Email">
                                <i class="fas fa-envelope text-primary me-2"></i><a href="mailto:@item.Email" class="text-decoration-none text-muted">@(item.Email ?? "لا يوجد بريد")</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-footer bg-white border-top-0 d-flex justify-content-center gap-2 pb-3">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info flex-grow-1">التفاصيل</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                    </div>
                </div>
            </div>
        }
    }
</div>