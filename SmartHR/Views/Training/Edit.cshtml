@model SmartHR.Models.TrainingProgram

@{
    ViewData["Title"] = "تعديل الدورة التدريبية";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-edit text-primary me-2"></i> تحديث بيانات الدورة</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">عنوان الدورة</label>
                        <input asp-for="Title" class="form-control form-control-lg" required />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">الوصف والمحاور</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row bg-light p-3 rounded mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Instructor" class="form-label fw-bold">المدرب</label>
                            <input asp-for="Instructor" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-bold">الحالة</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Upcoming">قادمة (لم تبدأ)</option>
                                <option value="Ongoing">قيد التنفيذ</option>
                                <option value="Completed">مكتملة</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="StartDate" class="form-label fw-bold">تاريخ البداية</label>
                            <input asp-for="StartDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold">تاريخ النهاية</label>
                            <input asp-for="EndDate" type="date" class="form-control" required />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-3">
                        <a asp-action="Index" class="btn btn-light border"><i class="fas fa-arrow-right me-1"></i> تراجع</a>
                        <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i> حفظ التحديثات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}