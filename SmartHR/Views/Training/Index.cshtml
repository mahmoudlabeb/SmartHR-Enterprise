@model IEnumerable<SmartHR.Models.TrainingProgram>

@{
    ViewData["Title"] = "إدارة التدريب والتطوير";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-chalkboard-teacher text-primary me-2"></i> البرامج التدريبية</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus me-1"></i> إضافة دورة جديدة
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 border-top border-primary border-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">عنوان الدورة</th>
                        <th>المدرب / الجهة</th>
                        <th class="text-center">الفترة</th>
                        <th class="text-center">الحالة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-book-reader fa-3x mb-3 opacity-50"></i>
                                <h5>لا توجد برامج تدريبية مسجلة حالياً.</h5>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="fas fa-graduation-cap text-secondary me-2"></i>@item.Title
                                </td>
                                <td><span class="badge bg-light text-dark border"><i class="fas fa-user-tie me-1"></i> @item.Instructor</span></td>
                                <td class="text-center small">
                                    <span class="d-block text-success fw-bold">من: @item.StartDate.ToString("dd MMM yyyy")</span>
                                    <span class="d-block text-danger fw-bold">إلى: @item.EndDate.ToString("dd MMM yyyy")</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Status == "Upcoming")
                                    {
                                        <span class="badge bg-info text-dark">قادمة</span>
                                    }
                                    else if (item.Status == "Ongoing")
                                    {

                                        <span class="badge bg-primary">قيد التنفيذ</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-success">مكتملة</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info border" title="إدارة المتدربين والتفاصيل"><i class="fas fa-cog"></i> إدارة</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border" title="تعديل"><i class="fas fa-edit"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>