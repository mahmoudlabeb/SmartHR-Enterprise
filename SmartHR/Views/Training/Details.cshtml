@model SmartHR.Models.TrainingProgram

@{
    ViewData["Title"] = "لوحة إدارة التدريب";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-laptop-code text-info me-2"></i> إدارة: @Model.Title</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="fas fa-edit me-1"></i> تعديل الدورة</a>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-list me-1"></i> قائمة البرامج</a>
    </div>
</div>

<div class="row">
    <div class="col-md-7 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold text-dark"><i class="fas fa-info-circle text-primary me-2"></i> نظرة عامة</h5>
                @if (Model.Status == "Upcoming")
                {
                    <span class="badge bg-info text-dark px-3 py-2 fs-6">دورة قادمة</span>
                }
                else if (Model.Status == "Ongoing")
                {

                    <span class="badge bg-primary px-3 py-2 fs-6"><i class="fas fa-spinner fa-spin me-1"></i> قيد التنفيذ</span>
                }
                else
                {

                    <span class="badge bg-success px-3 py-2 fs-6"><i class="fas fa-check-double me-1"></i> مكتملة</span>
                }
            </div>
            <div class="card-body p-4">
                <h6 class="text-muted fw-bold mb-3">محاور وأهداف الدورة:</h6>
                <div class="bg-light p-3 rounded mb-4 text-dark" style="min-height: 100px; white-space: pre-wrap;">@(string.IsNullOrEmpty(Model.Description) ? "لا يوجد وصف مدون." : Model.Description)</div>

                <hr class="bg-light my-4" />

                <div class="row text-center mb-2">
                    <div class="col-4 border-end">
                        <small class="text-muted d-block mb-1">تاريخ البداية</small>
                        <h6 class="fw-bold text-success"><i class="far fa-calendar-alt me-1"></i> @Model.StartDate.ToString("dd MMM yyyy")</h6>
                    </div>
                    <div class="col-4 border-end">
                        <small class="text-muted d-block mb-1">تاريخ النهاية</small>
                        <h6 class="fw-bold text-danger"><i class="far fa-calendar-check me-1"></i> @Model.EndDate.ToString("dd MMM yyyy")</h6>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block mb-1">المدرب / الجهة</small>
                        <h6 class="fw-bold text-primary"><i class="fas fa-user-tie me-1"></i> @Model.Instructor</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5 mb-4">
        <partial name="_TraineeList" model="new List<SmartHR.Models.Employee>()" />
    </div>
</div>