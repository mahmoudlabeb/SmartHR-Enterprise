@model IEnumerable<SmartHR.Models.Employee>

<div class="card shadow-sm border-0 mb-4 h-100">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="m-0 fw-bold text-dark"><i class="fas fa-users text-info me-2"></i> قائمة المتدربين</h6>
        <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#addTraineeModal">
            <i class="fas fa-user-plus me-1"></i> إضافة متدرب
        </button>
    </div>
    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
        <ul class="list-group list-group-flush">
            @if (Model == null || !Model.Any())
            {
                <li class="list-group-item text-center text-muted py-4">
                    <i class="fas fa-user-graduate fa-2x mb-2 opacity-50"></i>
                    <p class="mb-0 small">لم يتم تسجيل أي متدربين في هذه الدورة حتى الآن.</p>
                </li>
            }
            else
            {
                @foreach (var trainee in Model)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center p-3 hover-bg-light transition-all">
                        <div class="d-flex align-items-center">
                            <img src="https://ui-avatars.com/api/?name=@trainee.FullName&background=random&size=40" class="rounded-circle shadow-sm me-3" />
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@trainee.FullName</h6>
                                <small class="text-muted">@(trainee.Department?.Name ?? "غير محدد")</small>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-light text-danger border" title="إلغاء التسجيل">
                            <i class="fas fa-user-minus"></i>
                        </button>
                    </li>
                }
            }
        </ul>
    </div>
</div>

<div class="modal fade" id="addTraineeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus-circle text-primary me-2"></i> تسجيل موظف في الدورة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="addTraineeForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر الموظف</label>
                        <select class="form-select" id="traineeSelect">
                            <option value="">-- يرجى الاختيار --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i> تسجيل المتدرب</button>
            </div>
        </div>
    </div>
</div>