@model SmartHR.Models.Project

@{
    ViewData["Title"] = "إلغاء المشروع";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2 text-danger"><i class="fas fa-exclamation-triangle me-2"></i> تأكيد إلغاء المشروع</h1>
</div>

<div class="alert alert-danger shadow-sm p-4" role="alert">
    <h4 class="alert-heading fw-bold mb-3">هل أنت متأكد من رغبتك في إلغاء هذا المشروع نهائياً؟</h4>
    <p>سيتم حذف المشروع بالكامل <strong>(@Model.Name)</strong> بما في ذلك ارتباطاته بفريق العمل. لا يمكن التراجع عن هذه الخطوة.</p>
    <hr>

    <div class="bg-white p-3 rounded text-dark mt-3">
        <h5 class="mb-1 fw-bold">@Model.Name</h5>
        <p class="text-muted small mb-0 text-truncate">@Model.Description</p>
    </div>
</div>

<form asp-action="Delete" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger px-4 me-2"><i class="fas fa-trash-alt me-2"></i> نعم، إلغاء المشروع</button>
    <a asp-action="Index" class="btn btn-light border">تراجع والعودة للقائمة</a>
</form>