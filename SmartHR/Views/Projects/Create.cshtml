@model SmartHR.Models.Project

@{
    ViewData["Title"] = "إضافة مشروع جديد";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-folder-plus text-success me-2"></i> إضافة مشروع جديد</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-success border-4">
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">اسم المشروع <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="أدخل اسم المشروع بوضوح..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">الوصف والأهداف</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="تفاصيل المشروع، نطاق العمل، والأهداف..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row bg-light p-3 rounded mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="StartDate" class="form-label fw-bold"><i class="far fa-calendar-plus text-success me-1"></i> تاريخ البداية</label>
                            <input asp-for="StartDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold"><i class="far fa-calendar-check text-danger me-1"></i> تاريخ النهاية المتوقع</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-bold">الحالة المبدئية</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active" selected>نشط (قيد التنفيذ)</option>
                            <option value="Pending">معلق (قيد الدراسة)</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="text-decoration-none text-muted"><i class="fas fa-arrow-right me-1"></i> تراجع</a>
                        <button type="submit" class="btn btn-success px-5"><i class="fas fa-save me-2"></i> إطلاق المشروع</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}