@model SmartHR.Models.Project

@{
    ViewData["Title"] = "تعديل المشروع";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-edit text-primary me-2"></i> تعديل بيانات المشروع</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i> العودة</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">اسم المشروع</label>
                        <input asp-for="Name" class="form-control form-control-lg" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">الوصف</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row bg-light p-3 rounded mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="StartDate" class="form-label fw-bold">تاريخ البداية</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold">تاريخ النهاية المتوقع</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-bold">تحديث الحالة</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">نشط (قيد التنفيذ)</option>
                            <option value="Pending">معلق (متوقف مؤقتاً)</option>
                            <option value="Completed">مكتمل</option>
                        </select>
                    </div>

                    <div class="text-end mt-4">
                        <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i> حفظ التعديلات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}