@model IEnumerable<SmartHR.Models.TaskItem>
@using SmartHR.Models
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["TaskAssignmentBoard"];
}

<div class="row g-4 py-4 animate__animated animate__fadeIn">
    <div class="col-12 d-flex justify-content-between align-items-center mb-2">
        <div>
            <h1 class="h3 fw-bold text-white mb-1"><i class="fas fa-tasks text-primary me-2"></i> @Localizer["TaskAssignmentBoard"]</h1>
            <p class="text-white-50 mb-0">@Localizer["ManageWorkflowsAndAssignments"]</p>
        </div>
        <button type="button" class="btn btn-primary shadow-sm px-4 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#assignTaskModal">
            <i class="fas fa-plus-circle me-2"></i> @Localizer["AssignNewTask"]
        </button>
    </div>

    <!-- Kanban Columns -->
    <div class="row g-4 mt-1">
        <!-- Pending -->
        <div class="col-md-4">
            <div class="kanban-column rounded-3 bg-dark-secondary p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-warning border-2">
                    <h5 class="fw-bold text-warning mb-0 uppercase tracking-widest"><i class="fas fa-layer-group me-2"></i> @Localizer["Pending"]</h5>
                    <span class="badge bg-warning text-dark rounded-pill">@Model.Count(t => t.Status == SmartHR.Models.TaskStatus.Pending)</span>
                </div>
                
                @foreach (var task in Model.Where(t => t.Status == SmartHR.Models.TaskStatus.Pending))
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>

        <!-- In Progress -->
        <div class="col-md-4">
            <div class="kanban-column rounded-3 bg-dark-secondary p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-primary border-2">
                    <h5 class="fw-bold text-primary mb-0 uppercase tracking-widest"><i class="fas fa-spinner fa-spin-pulse me-2"></i> @Localizer["InProgress"]</h5>
                    <span class="badge bg-primary rounded-pill">@Model.Count(t => t.Status == SmartHR.Models.TaskStatus.InProgress)</span>
                </div>
                
                @foreach (var task in Model.Where(t => t.Status == SmartHR.Models.TaskStatus.InProgress))
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>

        <!-- Completed -->
        <div class="col-md-4">
            <div class="kanban-column rounded-3 bg-dark-secondary p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-success border-2">
                    <h5 class="fw-bold text-success mb-0 uppercase tracking-widest"><i class="fas fa-check-double me-2"></i> @Localizer["Completed"]</h5>
                    <span class="badge bg-success rounded-pill">@Model.Count(t => t.Status == SmartHR.Models.TaskStatus.Completed)</span>
                </div>
                
                @foreach (var task in Model.Where(t => t.Status == SmartHR.Models.TaskStatus.Completed))
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>
    </div>
</div>

<style>
    .kanban-column { background-color: rgba(255, 255, 255, 0.03); min-height: 70vh; }
    .bg-dark-secondary { background-color: #15181c; }
    .uppercase { text-transform: uppercase; }
    .tracking-widest { letter-spacing: 0.15em; }
</style>

<!-- Reusable Task Card Partial Logic (Simulated here for speed, ideally a real partial) -->
@section Scripts {
    <script>
        // Any Kanban specific interactivity
    </script>
}

@section Modals {
    <!-- Modal container moved to bottom of view to prevent z-index/backdrop conflicts -->
    <div class="modal fade" id="assignTaskModal" tabindex="-1" aria-labelledby="assignTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-secondary shadow-2xl" style="background-color: #1a1d21;">
                <div class="modal-header border-secondary p-4">
                    <h5 class="modal-title fw-bold text-white" id="assignTaskModalLabel"><i class="fas fa-calendar-plus text-primary me-2"></i> @Localizer["AssignNewTask"]</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Create" asp-controller="Tasks" method="post">
                    <div class="modal-body p-4 bg-dark-light">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label text-white-50 small uppercase fw-bold">@Localizer["TaskTitle"]</label>
                                <input name="Title" class="form-control bg-dark text-white border-secondary py-2 shadow-none" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white-50 small uppercase fw-bold">@Localizer["SelectProject"]</label>
                                <select name="ProjectId" class="form-select bg-dark text-white border-secondary py-2 shadow-none" asp-items="ViewBag.ProjectsList">
                                    <option value="">-- @Localizer["CommonProject"] --</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-white-50 small uppercase fw-bold">@Localizer["Description"]</label>
                                <textarea name="Description" class="form-control bg-dark text-white border-secondary shadow-none" rows="3"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white-50 small uppercase fw-bold">@Localizer["AssignToMember"]</label>
                                <select name="AssignedToId" class="form-select bg-dark text-white border-secondary py-2 shadow-none" asp-items="ViewBag.EmployeesList" required>
                                    <option value="">-- @Localizer["SelectEmployee"] --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white-50 small uppercase fw-bold">@Localizer["DueDate"]</label>
                                <input type="date" name="DueDate" class="form-control bg-dark text-white border-secondary py-2 shadow-none" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary p-4">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow-lg">@Localizer["ConfirmAndAssign"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
