@model IEnumerable<SmartHR.Models.TaskItem>

@{
    ViewData["Title"] = "لوحة المهام (Kanban)";

    // تقسيم المهام حسب الحالة
    var pendingTasks = Model.Where(t => t.Status == "Pending");
    var inProgressTasks = Model.Where(t => t.Status == "InProgress");
    var completedTasks = Model.Where(t => t.Status == "Completed");
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-columns text-primary me-2"></i> لوحة المهام (Kanban)</h1>
    <div class="btn-group">
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-list me-1"></i> عرض كقائمة</a>
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fas fa-plus me-1"></i> مهمة جديدة</a>
    </div>
</div>

<div class="row kanban-board">
    <div class="col-md-4 mb-4">
        <div class="card bg-light border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
                <h6 class="fw-bold text-secondary text-uppercase mb-0">
                    <i class="fas fa-list-ul me-2"></i> قيد الانتظار
                    <span class="badge bg-secondary rounded-pill float-end">@pendingTasks.Count()</span>
                </h6>
            </div>
            <div class="card-body px-2" style="min-height: 500px;">
                @foreach (var task in pendingTasks)
                {
                    <partial name="_TaskCard" model="task" />
                }
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card bg-light border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
                <h6 class="fw-bold text-primary text-uppercase mb-0">
                    <i class="fas fa-spinner fa-spin me-2"></i> قيد التنفيذ
                    <span class="badge bg-primary rounded-pill float-end">@inProgressTasks.Count()</span>
                </h6>
            </div>
            <div class="card-body px-2" style="min-height: 500px;">
                @foreach (var task in inProgressTasks)
                {
                    <partial name="_TaskCard" model="task" />
                }
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card bg-light border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
                <h6 class="fw-bold text-success text-uppercase mb-0">
                    <i class="fas fa-check-double me-2"></i> مكتملة
                    <span class="badge bg-success rounded-pill float-end">@completedTasks.Count()</span>
                </h6>
            </div>
            <div class="card-body px-2" style="min-height: 500px;">
                @foreach (var task in completedTasks)
                {
                    <partial name="_TaskCard" model="task" />
                }
            </div>
        </div>
    </div>
</div>