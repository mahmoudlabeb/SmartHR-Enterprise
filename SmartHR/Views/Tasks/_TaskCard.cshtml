@model SmartHR.Models.TaskItem
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    var priorityColor = Model.Priority == "High" ? "danger" : Model.Priority == "Medium" ? "warning" : "info";
    var priorityText = Localizer[Model.Priority];
    
    // Status Logic
    var isOverdue = Model.DueDate < DateTime.Today && Model.Status != "Completed";
    var isFuture = Model.DueDate > DateTime.Today.AddDays(7);
}

<div class="card shadow-sm border-0 mb-3 kanban-card bg-dark position-relative hover-elevate @(isOverdue ? "border-end border-danger border-4" : "")">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge bg-@priorityColor bg-opacity-10 text-@priorityColor border border-@priorityColor rounded-pill px-2 py-1 small">
                <i class="fas fa-circle f-8 me-1"></i> @priorityText
            </span>
            @if (Model.Project != null)
            {
                <span class="text-primary-emphasis small fw-bold"><i class="fas fa-briefcase me-1"></i> @Model.Project.Name</span>
            }
            else
            {
                <span class="text-white-50 small"><i class="fas fa-folder me-1"></i> @Localizer["GeneralTasks"]</span>
            }
        </div>

        <h6 class="fw-bold text-white mb-1">@Model.Title</h6>
        <p class="text-white-50 small mb-3 text-truncate-2">@Model.Description</p>

        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top border-secondary">
            <div class="d-flex align-items-center">
                <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.AssignedEmployee?.FullName ?? Localizer["Unassigned"].Value))&background=6366f1&color=fff&size=24" 
                     class="rounded-circle me-2 border border-2 border-dark" />
                <span class="small text-white-50">@(Model.AssignedEmployee?.FullName ?? Localizer["Unassigned"].Value)</span>
            </div>

            <div class="text-end">
                @if (isOverdue)
                {
                    <span class="badge bg-danger text-white rounded-pill px-2 py-1 x-small animate__animated animate__pulse animate__infinite">
                        <i class="fas fa-exclamation-triangle me-1"></i> @Localizer["Overdue"]
                    </span>
                }
                else if (isFuture)
                {
                    <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-2 py-1 x-small">
                        <i class="fas fa-calendar-check me-1"></i> @Localizer["Upcoming"]
                    </span>
                }
                <div class="small text-white-50 mt-1">
                    <i class="far fa-clock me-1"></i> @Model.DueDate.ToShortDateString()
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .kanban-card { background-color: rgba(255, 255, 255, 0.05) !important; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .kanban-card:hover { transform: translateY(-5px); background-color: rgba(255, 255, 255, 0.08) !important; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3); }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .x-small { font-size: 0.7rem; }
    .f-8 { font-size: 8px; }
</style>