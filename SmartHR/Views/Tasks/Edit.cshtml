@model SmartHR.Models.TaskItem

@{
    ViewData["Title"] = "تعديل المهمة";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-edit text-success me-2"></i> تحديث المهمة</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 border-top border-success border-4">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">عنوان المهمة</label>
                        @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                        {
                            <input asp-for="Title" class="form-control form-control-lg" readonly />
                        }
                        else
                        {
                            <input asp-for="Title" class="form-control form-control-lg" required />
                        }
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">التفاصيل والوصف</label>
                        @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                        {
                            <textarea asp-for="Description" class="form-control" rows="4" readonly></textarea>
                        }
                        else
                        {
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        }
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="ProjectId" class="form-label fw-bold">المشروع التابع له</label>
                            @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                            {
                                <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.ProjectsList" disabled>
                                    <option value="">-- مهمة عامة --</option>
                                </select>
                                <input type="hidden" asp-for="ProjectId" />
                            }
                            else
                            {
                                <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.ProjectsList">
                                    <option value="">-- مهمة عامة --</option>
                                </select>
                            }
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedToId" class="form-label fw-bold">إسناد إلى الموظف</label>
                            @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                            {
                                <select asp-for="AssignedToId" class="form-select" asp-items="ViewBag.EmployeesList" disabled></select>
                                <input type="hidden" asp-for="AssignedToId" />
                            }
                            else
                            {
                                <select asp-for="AssignedToId" class="form-select" asp-items="ViewBag.EmployeesList" required></select>
                            }
                        </div>
                    </div>

                    <div class="row bg-light p-3 rounded mb-4">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label asp-for="Priority" class="form-label fw-bold">الأولوية</label>
                            @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                            {
                                <select asp-for="Priority" class="form-select" disabled>
                                    <option value="Low">عادية</option>
                                    <option value="Medium">متوسطة</option>
                                    <option value="High">عاجلة</option>
                                </select>
                                <input type="hidden" asp-for="Priority" />
                            }
                            else
                            {
                                <select asp-for="Priority" class="form-select">
                                    <option value="Low">عادية</option>
                                    <option value="Medium">متوسطة</option>
                                    <option value="High">عاجلة</option>
                                </select>
                            }
                        </div>
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label asp-for="Status" class="form-label fw-bold text-success">الحالة الحالية</label>
                            <select asp-for="Status" class="form-select border-success">
                                <option value="Pending">قيد الانتظار</option>
                                <option value="InProgress">قيد التنفيذ</option>
                                <option value="Completed">مكتملة</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DueDate" class="form-label fw-bold">تاريخ التسليم</label>
                            @if (User.IsInRole(SmartHR.Models.AppRoles.Employee) && !User.IsInRole(SmartHR.Models.AppRoles.Admin) && !User.IsInRole(SmartHR.Models.AppRoles.HR) && !User.IsInRole(SmartHR.Models.AppRoles.Manager))
                            {
                                <input asp-for="DueDate" type="date" class="form-control" readonly />
                            }
                            else
                            {
                                <input asp-for="DueDate" type="date" class="form-control" required />
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="TaskAssignment" class="btn btn-light border"><i class="fas fa-arrow-right me-1"></i> تراجع</a>
                        <button type="submit" class="btn btn-success px-5"><i class="fas fa-save me-2"></i> حفظ التحديثات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>