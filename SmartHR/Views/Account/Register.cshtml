@using SmartHR.ViewModels
@model RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب جديد - SmartHR</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #121212;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #1e1e1e;
            border: 1px solid #2d2d3a;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.6);
            padding: 3rem;
            width: 100%;
            max-width: 500px;
            color: #e0e0e0;
        }
        .form-control {
            background-color: #121212;
            border: 1px solid #2d2d3a;
            color: #fff;
        }
        .form-control:focus {
            background-color: #121212;
            color: #fff;
            border-color: #6366f1;
            box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
        }
        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border: none;
            padding: 0.8rem;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
        }
    </style>
</head>
<body>

    <div class="login-card p-4 p-md-5 mt-4 mb-4" style="max-height: 90vh; overflow-y: auto;">
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: #6366f1;"><i class="fas fa-user-plus me-2"></i>إنشاء حساب</h2>
            <p class="text-muted">نظام إدارة الموارد البشرية الذكي</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="form-label text-muted small">الاسم الكامل <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#121212; border:1px solid #2d2d3a; color:#9ca3af;">
                        <i class="fas fa-user"></i>
                    </span>
                    <input asp-for="FullName" class="form-control" placeholder="اسمك الكامل" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="form-label text-muted small">البريد الإلكتروني <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#121212; border:1px solid #2d2d3a; color:#9ca3af;">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" dir="ltr" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="form-label text-muted small">كلمة المرور <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#121212; border:1px solid #2d2d3a; color:#9ca3af;">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" dir="ltr" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ConfirmPassword" class="form-label text-muted small">تأكيد كلمة المرور <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#121212; border:1px solid #2d2d3a; color:#9ca3af;">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" dir="ltr" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">
                تسجيل جديد <i class="fas fa-chevron-left ms-1"></i>
            </button>
            
            <div class="text-center mt-3">
                <span class="text-muted small">لديك حساب بالفعل؟</span>
                <a href="/Account/Login" class="small text-decoration-none fw-bold ms-1" style="color: #6366f1;">تسجيل الدخول</a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>