@using SmartHR.ViewModels
@model ResetPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "تعيين كلمة مرور جديدة";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0 rounded-lg mt-5">
            <div class="card-header bg-primary text-white text-center py-4">
                <h3 class="font-weight-light my-2">كلمة مرور جديدة</h3>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-controller="Account" asp-action="ResetPassword">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <input asp-for="Code" type="hidden" />

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" readonly />
                        <label asp-for="Email">البريد الإلكتروني</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                        <label asp-for="Password">كلمة المرور الجديدة</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                        <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4 mb-0">
                        <button class="btn btn-primary" type="submit">حفظ التغييرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}