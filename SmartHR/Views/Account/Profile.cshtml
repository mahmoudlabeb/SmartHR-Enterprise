@model SmartHR.Models.ApplicationUser
@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-user-circle text-primary me-2"></i> الملف الشخصي</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm text-center border-top border-primary border-4">
            <div class="card-body">
                <img src="https://ui-avatars.com/api/?name=@(Model.FullName ?? Model.UserName)&background=0D8ABC&color=fff&size=150" class="rounded-circle mb-3 shadow" alt="Profile Picture" />
                <h4 class="fw-bold">@Model.FullName</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <span class="badge bg-success mt-2 p-2">مستخدم نشط</span>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-bold">
                تعديل البيانات الأساسية
            </div>
            <div class="card-body">
                <form method="post" asp-action="UpdateProfile">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">الاسم بالكامل</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" readonly />
                        <small class="text-muted">لا يمكن تعديل البريد الإلكتروني لأسباب أمنية.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">تاريخ الانضمام</label>
                        <input type="text" class="form-control bg-light" value="@Model.HireDate.ToShortDateString()" readonly />
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i> حفظ التعديلات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>