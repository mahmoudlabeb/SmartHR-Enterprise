@model int
@{
    var docs = ViewBag.Documents as IEnumerable<SmartHR.Models.EmployeeDocument> ?? new List<SmartHR.Models.EmployeeDocument>();
    var today = DateTime.UtcNow.Date;
}

<div class="card shadow-lg mt-4 animate__animated animate__fadeIn">
    <div class="card-header bg-transparent py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold" style="color: var(--accent-primary)">
            <i class="fas fa-file-invoice me-2"></i> خزينة الوثائق الرقمية (Document Vault)
        </h5>
        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("HR") || User.IsInRole("Employee"))
        {
            <button type="button" class="btn btn-sm btn-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#uploadDocModal">
                <i class="fas fa-plus me-1"></i> رفع وثيقة جديدة
            </button>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light bg-opacity-10 text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">النوع</th>
                        <th>اسم الملف</th>
                        <th>تاريخ الانتهاء</th>
                        <th>الحالة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!docs.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted italic">
                                <i class="fas fa-folder-open d-block mb-2 fs-2 opacity-25"></i>
                                لا توجد وثائق مؤرشفة لهذا الموظف حالياً
                            </td>
                        </tr>
                    }
                    @foreach (var doc in docs)
                    {
                        var isExpiring = doc.ExpiryDate.HasValue && doc.ExpiryDate.Value.Date <= today.AddDays(30) && doc.ExpiryDate.Value.Date > today;
                        var isExpired = doc.ExpiryDate.HasValue && doc.ExpiryDate.Value.Date <= today;

                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3 rounded bg-primary bg-opacity-10 p-2 text-primary">
                                        <i class="fas @(doc.DocumentType == "Passport" ? "fa-passport" : doc.DocumentType == "ID" ? "fa-id-card" : "fa-file-contract")"></i>
                                    </div>
                                    <span class="fw-bold">@doc.DocumentType</span>
                                </div>
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 200px;" title="@doc.FileName">@doc.FileName</div>
                                <small class="text-muted d-block">@doc.Description</small>
                            </td>
                            <td>@(doc.ExpiryDate?.ToString("yyyy/MM/dd") ?? "---")</td>
                            <td>
                                @if (isExpired)
                                {
                                    <span class="badge bg-danger">منتهية الصلاحية</span>
                                }
                                else if (isExpiring)
                                {
                                    <span class="badge bg-warning text-dark">تنتهي قريباً</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-25 text-success">سارية</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a asp-controller="Employees" asp-action="DownloadDocument" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-info" title="تحميل"><i class="fas fa-download"></i></a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("HR"))
                                    {
                                        <form asp-controller="Employees" asp-action="DeleteDocument" asp-route-id="@doc.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذه الوثيقة؟');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadDocModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-upload me-2"></i> رفع وثيقة جديدة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Employees" asp-action="UploadDocument" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="employeeId" value="@Model" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">نوع الوثيقة</label>
                        <select name="docType" class="form-select" required>
                            <option value="Passport">جواز سفر (Passport)</option>
                            <option value="National ID">هوية وطنية (National ID)</option>
                            <option value="Contract">عقد عمل (Contract)</option>
                            <option value="Training Certificate">شهادة تدريب</option>
                            <option value="Health Insurance">تأمين طبي</option>
                            <option value="Other">أخرى</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">تاريخ الانتهاء (إن وجد)</label>
                        <input type="date" name="expiryDate" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">وصف بسيط</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="مثلاً: نسخة محدثة لعام 2024"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الملف</label>
                        <input type="file" name="file" class="form-control" required />
                        <small class="text-muted">الحد الأقصى 10 ميجابايت (PDF, JPG, PNG)</small>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary px-4 shadow">حفظ ورفع</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .icon-box {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
