@model Microsoft.AspNetCore.Identity.IdentityRole

@{
    ViewData["Title"] = "إضافة دور جديد";
}

<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-plus-square text-success me-2"></i> إنشاء دور (Role) جديد</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 border-top border-success border-4">
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">اسم الدور (باللغة الإنجليزية يفضل) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user-tag"></i></span>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="مثال: HRManager, Accountant..." required />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        <div class="form-text text-muted mt-2"><i class="fas fa-info-circle me-1"></i> تجنب استخدام المسافات في أسماء الأدوار لسهولة برمجتها في الـ Controllers.</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-top pt-4">
                        <a asp-action="Index" class="btn btn-light border px-4">إلغاء</a>
                        <button type="submit" class="btn btn-success px-5"><i class="fas fa-save me-2"></i> حفظ الدور</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}