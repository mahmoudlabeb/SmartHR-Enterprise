@model SmartHR.Models.Candidate

@{
    var statusColor = Model.Status == "Pending" ? "warning" :
                      Model.Status == "Reviewed" ? "info" :
                      Model.Status == "Interview" ? "primary" :
                      Model.Status == "Hired" ? "success" : "danger";

    var statusText = Model.Status == "Pending" ? "قيد المراجعة" :
                     Model.Status == "Reviewed" ? "تمت المشاهدة" :
                     Model.Status == "Interview" ? "مقابلة" :
                     Model.Status == "Hired" ? "تم التعيين" : "مرفوض";
}

<div class="card shadow-sm border-0 mb-3 border-end border-@statusColor border-4 hover-shadow">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="d-flex align-items-center">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random&size=40" class="rounded-circle me-3 shadow-sm" />
                <div>
                    <h6 class="mb-0 fw-bold text-dark text-truncate" style="max-width: 150px;" title="@Model.FullName">@Model.FullName</h6>
                    <small class="text-muted">@Model.AppliedAt.ToString("dd MMM yyyy")</small>
                </div>
            </div>
            <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor border border-@statusColor rounded-pill">@statusText</span>
        </div>

        <div class="small text-muted mb-3 mt-2">
            <div class="text-truncate" title="@Model.Email"><i class="fas fa-envelope text-secondary me-1"></i> @Model.Email</div>
            <div><i class="fas fa-phone-alt text-secondary me-1"></i> @Model.Phone</div>
        </div>

        <div class="d-flex justify-content-between border-top pt-2">
            <a href="@Model.ResumeUrl" target="_blank" class="btn btn-sm btn-light text-primary border"><i class="fas fa-file-pdf me-1"></i> السيرة الذاتية</a>
            <a asp-action="CandidateDetails" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">التفاصيل</a>
        </div>
    </div>
</div>