@model SmartHR.Models.Candidate

@{
    ViewData["Title"] = "ملف المتقدم";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-user-check text-info me-2"></i> ملف المتقدم: @Model.FullName</h1>
    <a asp-action="Candidates" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-arrow-right me-1"></i> العودة للقائمة</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 h-100 text-center">
            <div class="card-body pt-5">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=0D8ABC&color=fff&size=120" class="rounded-circle shadow mb-3" />
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted mb-3">متقدم لوظيفة: <strong>@(Model.JobPosting?.Title)</strong></p>

                <a href="@Model.ResumeUrl" target="_blank" class="btn btn-primary w-75 mb-3"><i class="fas fa-cloud-download-alt me-2"></i> تحميل السيرة الذاتية</a>

                <hr class="bg-light" />

                <ul class="list-unstyled text-start px-3 small">
                    <li class="mb-2"><i class="fas fa-envelope text-muted me-2"></i> @Model.Email</li>
                    <li class="mb-2"><i class="fas fa-phone text-muted me-2"></i> @Model.Phone</li>
                    <li><i class="fas fa-calendar-day text-muted me-2"></i> قدم في: @Model.AppliedAt.ToString("dd MMM yyyy")</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 fw-bold text-dark"><i class="fas fa-clipboard-list text-primary me-2"></i> إدارة حالة الطلب (ATS)</h6>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-light border mb-4">
                    <strong>الحالة الحالية:</strong>
                    <span class="badge @(Model.Status == "Hired" ? "bg-success" : Model.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark") fs-6 ms-2">
                        @Model.Status
                    </span>
                </div>

                <form asp-action="UpdateCandidateStatus" method="post" class="bg-light p-4 rounded border">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <h6 class="fw-bold mb-3">تحديث حالة المتقدم:</h6>
                    <div class="row">
                        <div class="col-md-8">
                            <select name="status" class="form-select form-select-lg">
                                <option value="Pending" selected="@(Model.Status == "Pending")">قيد المراجعة (Pending)</option>
                                <option value="Reviewed" selected="@(Model.Status == "Reviewed")">تمت مشاهدة السيرة (Reviewed)</option>
                                <option value="Interview" selected="@(Model.Status == "Interview")">تحديد مقابلة (Interview)</option>
                                <option value="Hired" selected="@(Model.Status == "Hired")">تم التعيين (Hired)</option>
                                <option value="Rejected" selected="@(Model.Status == "Rejected")">مرفوض (Rejected)</option>
                            </select>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <button type="submit" class="btn btn-success btn-lg w-100"><i class="fas fa-sync-alt me-1"></i> تحديث</button>
                        </div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <i class="fas fa-info-circle me-1"></i> تحديث الحالة قد يرسل إشعاراً أو بريداً إلكترونياً تلقائياً للمتقدم (حسب إعدادات النظام).
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>