@model IEnumerable<SmartHR.Models.JobPosting>

@{
    ViewData["Title"] = "إدارة التوظيف";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="fas fa-briefcase text-primary me-2"></i> الوظائف المتاحة</h1>
    <a asp-action="CreateJob" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus me-1"></i> طرح وظيفة جديدة
    </a>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-search-minus fa-3x mb-3 opacity-50"></i>
            <h5>لا توجد وظائف مطروحة حالياً.</h5>
        </div>
    }
    else
    {
        @foreach (var job in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 hover-shadow transition-all">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-secondary border border-secondary">@job.Department</span>
                            <span class="badge @(job.Status == "Open" ? "bg-success" : "bg-danger")">
                                @(job.Status == "Open" ? "متاحة" : "مغلقة")
                            </span>
                        </div>
                        <h5 class="fw-bold mb-1">@job.Title</h5>
                        <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt me-1 text-danger"></i> @job.Location • @job.Type</p>

                        <div class="bg-dark rounded p-2 text-center mb-3 border border-secondary shadow-sm" style="background-color: rgba(255,255,255,0.03) !important;">
                            <span class="fs-4 fw-bold text-primary">@(job.Candidates?.Count ?? 0)</span>
                            <span class="d-block small text-muted">متقدم للوظيفة</span>
                        </div>

                        <p class="card-text text-muted small text-truncate">@job.Description</p>
                    </div>
                    <div class="card-footer border-top-0 d-flex justify-content-between gap-2">
                        <a asp-action="JobDetails" asp-route-id="@job.Id" class="btn btn-sm btn-outline-info flex-grow-1">إدارة المتقدمين</a>
                        <a asp-action="EditJob" asp-route-id="@job.Id" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                    </div>
                </div>
            </div>
        }
    }
</div>